  "keyFeatures": [
    "Self-custodial wallet with 24-word seed phrases",
    "Multi-chain EVM support (Ethereum, Arbitrum, Base, Optimism, Polygon)",
    "Client-side encryption and transaction signing",
    "Send native tokens and ERC-20s with gas estimation",
    "Token swaps with quote aggregation (0x, 1inch)",
    "Portfolio tracking with real-time USD valuations",
    "Payment request system for business accounts",
    "ENS name resolution",
    "Self-hostable with Docker",
    "Multi-language support (English, Spanish)"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Create new user account",
    "POST /api/auth/login - Authenticate user",
    "POST /api/auth/logout - End session",
    "GET /api/portfolio - Fetch multi-chain portfolio balances and USD values",
    "GET /api/addresses - List user wallet addresses",
    "POST /api/addresses - Add new wallet address",
    "GET /api/contacts - Fetch address book contacts",
    "POST /api/contacts - Create new contact",
    "POST /api/tx - Broadcast signed transaction",
    "GET /api/tx/activity - Get transaction history",
    "POST /api/swap/quote - Get swap quote for token pair",
    "GET /api/swap/price - Get current swap price",
    "POST /api/payment-requests - Create payment request (business only)",
    "GET /api/payment-requests/{id} - Get payment request status",
    "GET /api/payment-requests/history - List payment requests",
    "GET /api/prices - Get token prices",
    "GET /api/token-images - Get token image URLs",
    "GET /api/profile - Get user profile",
    "PATCH /api/profile - Update user profile"
  ]
}
